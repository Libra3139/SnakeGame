# ============================================================
# Pusher Channels 設定 (必填)
# 前往 https://pusher.com/channels 註冊免費帳號，
# 建立一個 Channels App 後取得以下憑證。
# ============================================================

# 公開金鑰（Client 端用，以 VITE_ 前綴讓 Vite 暴露給瀏覽器）
VITE_PUSHER_KEY=your_pusher_key_here

# 叢集代碼（如 us2, ap1, eu 等）
VITE_PUSHER_CLUSTER=us2

# 伺服器端用（Vercel Serverless Function 讀取）
PUSHER_APP_ID=your_pusher_app_id_here
PUSHER_KEY=your_pusher_key_here
PUSHER_SECRET=your_pusher_secret_here
PUSHER_CLUSTER=us2
